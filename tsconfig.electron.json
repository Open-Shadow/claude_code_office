{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["electron/**/*.ts", "shared/**/*.ts"],
  "exclude": [
    "node_modules",
    "electron/fileWatcher.ts",
    "electron/transcriptParser.ts",
    "electron/timerManager.ts",
    "electron/types.ts"
  ]
}
